class GameObject:
    def __init__(self, x, y, z, size, color, type="cube"):
        self.pos = [x, y, z]
        self.size = size
        self.color = color
        self.type = type
        self.rotation = 0
        self.move_dir = 1
        self.start_x = x
        self.anim_offset = random.uniform(0, 10)

def init_level(level):
    global current_level, player_pos, coins, obstacles, decorations
    global total_coins, time_limit, player_speed, start_time, coins_collected
    global level_complete, game_over, player_health, showing_level_screen, level_screen_timer
    global destination_z, destination_reached
    global cheat_fly, cheat_speed, cheat_noclip, cheat_inf_jump, cheat_magnet, cheat_reveal

    current_level = level
 
    # ---- Default difficulty (safe values) ----
    coin_mult = 1.0
    obs_mult = 1.0

    player_pos = [0.0, 15.0, 0.0]
    coins = []
    obstacles = []

    decorations = []
    coins_collected = 0
    level_complete = False
    game_over = False
    player_health = 100
    start_time = time.time()
    showing_level_screen = True
    level_screen_timer = time.time()

    global level_start_score, game_score
    game_score = 0
    level_start_score = 0

    # --- Level settings ---
    base_map_length = 10000
    map_length = base_map_length + (level * 2000)
    # ----- Difficulty based base speed -----

    # ----- Difficulty multipliers -----
    if selected_mode == 'Easy':
        coin_mult = 1.0
        obs_mult = 1.0
    elif selected_mode == 'Medium':
        coin_mult = 1.5
        obs_mult = 1.7
    elif selected_mode == 'Hard':
        coin_mult = 2.2
        obs_mult = 2.5

# ----- Base amounts ----- 
    base_coins = 60 + (level * 60)
    base_obstacles = 30 + (level * 10)

# ----- Final scaled amounts -----
    total_coins = int(base_coins * coin_mult)
    num_obstacles = int(base_obstacles * obs_mult)

    time_limit = max(30, 200 - (level * 30))
    destination_z = -map_length + 200
    destination_reached = False
    if selected_mode == 'Easy':
        player_speed = 6.0
    elif selected_mode == 'Medium':
        player_speed = 10.0
    elif selected_mode == 'Hard':
        player_speed = 15.0

   
    # --- Reset all cheats OFF ---
    cheat_fly = False
    cheat_speed = False 
    cheat_noclip = False
    cheat_inf_jump = False
    cheat_magnet = False
    cheat_reveal = False
    speed_multiplier = 1.0


    # --- Spawn coins ---
    for i in range(total_coins):
        z_pos = -random.uniform(200, map_length)
        x_pos = random.choice([-70, 0, 70])
        coins.append(GameObject(x_pos, 15 + math.sin(i)*5, z_pos, 10, (1.0, 0.9, 0.0), "coin"))

    # --- Spawn obstacles ---
    acc_types = ["cupcake", "ring", "block", "star"]
    for i in range(num_obstacles):
        z_pos = -random.uniform(300, map_length)
        x_pos = random.choice([-70, 0, 70])
        obs_type = random.choice(acc_types)
        color = (random.uniform(0.6, 1), random.uniform(0.4, 0.9), random.uniform(0.6, 1))
        obstacles.append(GameObject(x_pos, 15, z_pos, 25, color, obs_type))

    # --- Decorations ---
    for i in range(150):
        side = random.choice([-1, 1])
        decorations.append(GameObject(side * random.uniform(180, 600), 0, -random.uniform(0, map_length), 40, (0,0,0), "rainbow_tree"))

 
def draw_destination():
    glPushMatrix()
    glTranslatef(0, 20, destination_z)  # Use the global destination_z
    glColor3f(0.0, 1.0, 0.3)
    glutSolidTorus(5, 40, 20, 40)
    glPopMatrix()


# --- Intro Screen ---
def draw_intro_screen():
    glClearColor(0.1, 0.1, 0.2, 1.0)
    glClear(GL_COLOR_BUFFER_BIT | GL_DEPTH_BUFFER_BIT)

    # Title
    draw_text(WINDOW_WIDTH/2 - 100, WINDOW_HEIGHT - 100, "COINQUEST 3D", 3, (1, 1, 0.5))
    draw_text(WINDOW_WIDTH/2 - 180, WINDOW_HEIGHT - 150, "SELECT DIFFICULTY MODE", 2, (1, 0.7, 0.3))

    # Draw clickable rectangles (so mouse can select)
    def draw_rect(x, y, w, h, color):
        glColor3f(*color)
        glBegin(GL_QUADS)
        glVertex2f(x, y)
        glVertex2f(x + w, y)
        glVertex2f(x + w, y + h)
        glVertex2f(x, y + h)
        glEnd()

    # --- Setup 2D coordinates ---
    glMatrixMode(GL_PROJECTION)
    glPushMatrix()
    glLoadIdentity()
    gluOrtho2D(0, WINDOW_WIDTH, 0, WINDOW_HEIGHT)
    glMatrixMode(GL_MODELVIEW)
    glPushMatrix()
    glLoadIdentity()

    # --- Define rectangles ---
    button_width = 100
    button_height = 40
    center_x = WINDOW_WIDTH / 2 - button_width / 2

    # Y positions
    easy_y = WINDOW_HEIGHT - 300
    medium_y = WINDOW_HEIGHT - 450
    hard_y = WINDOW_HEIGHT - 600

    # Easy Button
    draw_rect(center_x, easy_y, button_width, button_height, (0, 0.5, 0))
    draw_text(center_x + 20, easy_y + 10, "Easy", 2, (1,1,1))

    # Medium Button
    draw_rect(center_x, medium_y, button_width, button_height, (0.7, 0.7, 0))
    draw_text(center_x + 10, medium_y + 10, "Medium", 2, (0,0,0))

    # Hard Button
    draw_rect(center_x, hard_y, button_width, button_height, (0.7, 0, 0))
    draw_text(center_x + 20, hard_y + 10, "Hard", 2, (1,1,1))

    # Restore matrices
    glPopMatrix()
    glMatrixMode(GL_PROJECTION)
    glPopMatrix()
    glMatrixMode(GL_MODELVIEW)

    glutSwapBuffers()


# --- Mouse Click Handler ---
def mouse_click(button, state, x, y):
    global showing_intro_screen, selected_mode

    if not showing_intro_screen:
        return

    if button == GLUT_LEFT_BUTTON and state == GLUT_DOWN:
        # Convert y from top-left (window) to OpenGL coordinates (bottom-left)
        y = WINDOW_HEIGHT - y

        # Buttons coordinates (same as draw_intro_screen)
        button_width = 100
        button_height = 40
        center_x = WINDOW_WIDTH / 2 - button_width / 2
        easy_y = WINDOW_HEIGHT - 300
        medium_y = WINDOW_HEIGHT - 450
        hard_y = WINDOW_HEIGHT - 600

        # Easy
        if center_x <= x <= center_x + button_width and easy_y <= y <= easy_y + button_height:
            selected_mode = 'Easy'
            init_level(1)
            showing_intro_screen = False

        # Medium
        elif center_x <= x <= center_x + button_width and medium_y <= y <= medium_y + button_height:
            selected_mode = 'Medium'
            init_level(2)
            showing_intro_screen = False

        # Hard
        elif center_x <= x <= center_x + button_width and hard_y <= y <= hard_y + button_height:
            selected_mode = 'Hard'
            init_level(3)
            showing_intro_screen = False

 



def draw_text(x, y, text, scale=1.0, color=(1,1,1)):
