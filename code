def draw_object(obj):
    glPushMatrix()
    glTranslatef(obj.pos[0], obj.pos[1], obj.pos[2])
    
    if obj.type == "coin":
        glRotatef(obj.rotation, 0, 1, 0)
        glColor3f(1.0, 0.9, 0.0)
        glutSolidTorus(3, 8, 15, 30)
        # Sparkle effect
        if random.random() > 0.9:
            glColor3f(1, 1, 1)
            glutSolidSphere(2, 5, 5)
            
    elif obj.type == "cupcake":
        # Base
        glColor3f(0.8, 0.5, 0.3)
        glPushMatrix()
        glRotatef(-90, 1, 0, 0)
        glutSolidCone(15, 15, 10, 10)
        glPopMatrix()
        # Frosting
        glColor3f(*obj.color)
        glTranslatef(0, 12, 0)
        glutSolidSphere(12, 20, 20)
        # Cherry
        glColor3f(1, 0, 0)
        glTranslatef(0, 10, 0)
        glutSolidSphere(4, 10, 10)
        
    elif obj.type == "ring":
        glRotatef(time.time()*100, 0, 0, 1)
        glColor3f(*obj.color)
        glutSolidTorus(5, 20, 10, 20)
        
    elif obj.type == "block":
        glColor3f(*obj.color)
        glRotatef(obj.rotation, 1, 1, 1)
        glutSolidCube(25)
        
    elif obj.type == "star":
        glColor3f(1, 1, 0)
        glRotatef(time.time()*200, 0, 1, 0)
        glutSolidOctahedron()
        
    elif obj.type == "rainbow_tree":
        # Trunk
        glColor3f(0.5, 0.3, 0.2)
        glPushMatrix()
        glScalef(1, 8, 1)
        glutSolidCube(10)
        glPopMatrix()
        # Rainbow Leaves
        glTranslatef(0, 40, 0)
        for i in range(5):
            colors = [(1,0,0), (1,0.5,0), (1,1,0), (0,1,0), (0,0,1)]
            glColor3f(*colors[i])
            glPushMatrix()
            glRotatef(i*72 + time.time()*20, 0, 1, 0)
            glTranslatef(15, math.sin(time.time()*2 + i)*5, 0)
            glutSolidSphere(15, 10, 10)
            glPopMatrix()

    glPopMatrix()

def draw_level_screen():
    # Animated background for level transition
    glClearColor(0.2, 0.1, 0.3, 1.0)
    glClear(GL_COLOR_BUFFER_BIT | GL_DEPTH_BUFFER_BIT)
    
    # Floating stars
    for i in range(20):
        x = (math.sin(time.time() + i) * 400) + WINDOW_WIDTH/2
        y = (math.cos(time.time()*0.5 + i) * 300) + WINDOW_HEIGHT/2
        draw_text(x, y, "*", 2, (1, 1, 0.5))
        
    draw_text(WINDOW_WIDTH/2 - 150, WINDOW_HEIGHT/2 + 50, f"PREPARING LEVEL {current_level}", 2, (1, 0.5, 1))
    draw_text(WINDOW_WIDTH/2 - 100, WINDOW_HEIGHT/2 - 20, "GET READY!", 1, (0.5, 1, 1))

def get_cheats_for_display():
    cheats = []
    if selected_mode == 'Easy':
        cheats = [
            ("Fly", cheat_fly),
            ("Speed", speed_multiplier > 1.0),
            ("No-Clip", cheat_noclip),
            ("Inf Jump", cheat_inf_jump),
            ("Magnet", cheat_magnet),
            ("Reveal", cheat_reveal)
        ]
    elif selected_mode == 'Medium':
        cheats = [
            ("Fly", cheat_fly),
            ("Speed", speed_multiplier > 1.0),
            ("Magnet", cheat_magnet)
        ]
    # Hard → empty list
    return cheats


def display():
    glClear(GL_COLOR_BUFFER_BIT | GL_DEPTH_BUFFER_BIT)
    glLoadIdentity()

    # --- INTRO SCREEN ---
    if showing_intro_screen:
        draw_intro_screen()
        return

    # --- LEVEL SCREEN ---
    if showing_level_screen:
        draw_level_screen()
        glutSwapBuffers()
        return

    # --- CAMERA ---
    gluLookAt(player_pos[0], player_pos[1] + 70, player_pos[2] + 220, 
              player_pos[0], player_pos[1], player_pos[2] - 100, 0, 1, 0)

    # --- GROUND ---
    for z in range(int(player_pos[2]/100) - 20, int(player_pos[2]/100) + 5):
        for x in [-1, 0, 1]:
            glPushMatrix()
            glTranslatef(x*70, 0, z*100)
            glColor3f(0.8, 1.0, 0.8) if (x+z)%2==0 else glColor3f(0.9, 0.9, 1.0)
            glBegin(GL_QUADS)
            glVertex3f(-35, 0, -50); glVertex3f(35, 0, -50)
            glVertex3f(35, 0, 50); glVertex3f(-35, 0, 50)
            glEnd()
            glPopMatrix()

    # --- OBJECTS ---
    for dec in decorations: draw_object(dec)
    for obs in obstacles: draw_object(obs)
    for coin in coins: draw_object(coin)
    draw_destination()
    draw_player()

    # --- UI ---
    draw_text(20, WINDOW_HEIGHT - 40, f"LEVEL: {current_level}", 1, (1, 0, 1))
    draw_text(20, WINDOW_HEIGHT - 70, f"SCORE: {game_score}", 1, (1, 1, 0))
    draw_text(20, WINDOW_HEIGHT - 100, f"HEALTH: {int(player_health)}", 1, (0, 1, 0))
    draw_text(20, WINDOW_HEIGHT - 130, f"COINS: {coins_collected}/{total_coins}", 1, (0, 1, 1))
    if not game_over:
        rem_time = max(0, int(time_limit - (time.time() - start_time)))
    else:
        rem_time = max(0, int(time_limit - (game_over_time - start_time)))  # freeze time at game over

    draw_text(20, WINDOW_HEIGHT - 160, f"TIME: {rem_time}s", 1, (1, 0.5, 0))


    # --- Cheat Modes ---
    cheat_texts = get_cheats_for_display()  # only allowed cheats for this level
    y_offset = 190
    for i, (name, status) in enumerate(cheat_texts):
        color = (0, 1, 0) if status else (1, 0, 0)
        draw_text(20, WINDOW_HEIGHT - y_offset - i*30, f"{name}: {'ON' if status else 'OFF'}", 1, color)

    # --- PAUSED ---
    if paused:
        draw_text(WINDOW_WIDTH//2 - 60, WINDOW_HEIGHT//2, "PAUSED", 2, (1, 0, 0))
        glutSwapBuffers()
        return

    # --- GAME OVER ---
    if game_over:
        draw_text(WINDOW_WIDTH//2 - 180, WINDOW_HEIGHT//2 + 20, "GAME OVER!", 2, (1, 0, 0))
        draw_text(WINDOW_WIDTH//2 - 180, WINDOW_HEIGHT//2 - 20, "PRESS 'R' TO RESTART", 1, (1, 1, 0))
        draw_text(WINDOW_WIDTH//2 - 180, WINDOW_HEIGHT//2 - 50, "PRESS 'B' TO RETURN TO MENU", 1, (0, 1, 1))
        glutSwapBuffers()
        return

    # --- LEVEL COMPLETE ---
    if level_complete:
        draw_text(WINDOW_WIDTH//2 - 150, WINDOW_HEIGHT//2, "LEVEL COMPLETE!", 2, (0, 0.7, 1))
        draw_text(WINDOW_WIDTH//2 - 180, WINDOW_HEIGHT//2 - 40, "RETURNING TO MENU...", 1, (1, 1, 0))
        glutSwapBuffers()
        return

    glutSwapBuffers()


def update(value):
    global player_pos, player_vel_y, is_jumping, coins_collected, game_score
    global level_complete, game_over, player_health, showing_level_screen
    global destination_reached, destination_z
    global showing_intro_screen, selected_mode
    global level_complete_time, game_over_time, start_time

    # --- PAUSE CHECK ---
    if paused:
        glutPostRedisplay()
        glutTimerFunc(16, update, 0)
        return

    # --- LEVEL INTRO SCREEN ---
    if showing_level_screen:
        if time.time() - level_screen_timer > 2.5:
            showing_level_screen = False
            start_time = time.time()
        glutPostRedisplay()
        glutTimerFunc(16, update, 0)
        return

    # --- LEVEL COMPLETE TIMER ---
    if level_complete and level_complete_time == 0:
        level_complete_time = time.time()

    if level_complete and level_complete_time > 0:
        if time.time() - level_complete_time > 2.5:
            showing_intro_screen = True
            selected_mode = None
            level_complete = False
            level_complete_time = 0

    # --- GAME OVER TIMER ---
    if game_over and game_over_time == 0:
        game_over_time = time.time()

    # --- PLAYER MOVEMENT / COLLISIONS ---
    if not game_over and not level_complete and not showing_level_screen:

        # Forward movement
        player_pos[2] -= player_speed * speed_multiplier

        # ---------- FLY / GRAVITY ----------
        if cheat_fly:
            player_vel_y = fly_speed
            player_pos[1] += player_vel_y
        else:
            player_vel_y += gravity
            player_pos[1] += player_vel_y
            if player_pos[1] <= 15.0:
                player_pos[1] = 15.0
                player_vel_y = 0
                is_jumping = False

        # --- DESTINATION CHECK ---
        if player_pos[2] <= destination_z and not destination_reached:
            destination_reached = True
            level_complete = True

        # --- COINS ---
        for coin in coins[:]:
            coin.rotation = (coin.rotation + 15) % 360

            if cheat_magnet:
                dist = math.sqrt(
                    (player_pos[0] - coin.pos[0]) ** 2 +
                    (player_pos[1] - coin.pos[1]) ** 2 +
                    (player_pos[2] - coin.pos[2]) ** 2
                )
                if dist < 250:
                    for i in range(3):
                        coin.pos[i] += (player_pos[i] - coin.pos[i]) * 0.25

            dist = math.sqrt(
                (player_pos[0] - coin.pos[0]) ** 2 +
                (player_pos[1] - coin.pos[1]) ** 2 +
                (player_pos[2] - coin.pos[2]) ** 2
            )
            if dist < 30:
                coins.remove(coin)
                coins_collected += 1
                game_score += 100
                if coins_collected >= total_coins:
                    level_complete = True

        # --- OBSTACLES ---
        for obs in obstacles:
            obs.rotation = (obs.rotation + 5) % 360
            if not cheat_noclip:
                dx = abs(player_pos[0] - obs.pos[0])
                dy = abs(player_pos[1] - obs.pos[1])
                dz = abs(player_pos[2] - obs.pos[2])
                if dx < 35 and dy < 35 and dz < 35:
                    player_health -= 1
                    if player_health <= 0:
                        game_over = True

        # --- TIME LIMIT ---
        # --- TIME LIMIT ---
        if not game_over and not level_complete and not showing_level_screen:
           elapsed = time.time() - start_time
           if elapsed > time_limit:
               game_over = True
               game_over_time = time.time()  # freeze the time display


    glutPostRedisplay()
    glutTimerFunc(16, update, 0)



def keyboard(key, x, y):
    global player_pos, player_vel_y, is_jumping
    global cheat_fly, cheat_speed, cheat_noclip
    global cheat_inf_jump, cheat_magnet, cheat_reveal
    global current_level, game_over, level_complete
    global showing_intro_screen, selected_mode
    global paused, speed_multiplier
    global fly_ascending


    # ---------- ESC PAUSE ----------
    if key == b'\x1b':  # ESC
        paused = not paused
        return

    # ---------- RESTART ----------
    if key == b'r':
        init_level(current_level)
        return

    # Return to menu if game over
    if key == b'b':
        if game_over:
            showing_intro_screen = True
            selected_mode = None
            game_over = False
